{
  "_comment": "DS2API config example. Copy to config.json and fill your own private credentials.",
  "_doc": "https://github.com/CJackHwang/ds2api",
  "keys": [
    "your-api-key-1",
    "your-api-key-2"
  ],
  "api_keys": [
    {
      "key": "your-api-key-1",
      "name": "Primary API Key",
      "remark": "Used by OpenAI-compatible clients"
    },
    {
      "key": "your-api-key-2",
      "name": "Backup API Key",
      "remark": "Used for tests or temporary clients"
    }
  ],
  "accounts": [
    {
      "email": "example1@example.com",
      "password": "your-password-1",
      "active": true,
      "muted": false,
      "mute_until": 0,
      "last_used": 0,
      "token": ""
    },
    {
      "mobile": "+8613800138000",
      "password": "your-password-2",
      "active": true,
      "muted": false,
      "mute_until": 0,
      "last_used": 0,
      "token": ""
    }
  ],
  "model_aliases": {
    "gpt-4o": "deepseek-chat",
    "gpt-5.5": "deepseek-chat",
    "gpt-5.3-codex": "deepseek-reasoner",
    "o3": "deepseek-reasoner"
  },
  "responses": {
    "store_ttl_seconds": 900
  },
  "current_input_file": {
    "enabled": true,
    "min_chars": 0
  },
  "thinking_injection": {
    "enabled": true,
    "prompt": ""
  },
  "embeddings": {
    "provider": "deterministic"
  },
  "admin": {
    "jwt_expire_hours": 24
  },
  "runtime": {
    "account_max_inflight": 2,
    "account_max_queue": 0,
    "global_max_inflight": 0,
    "token_refresh_interval_hours": 6
  },
  "auto_delete": {
    "mode": "none"
  }
}
